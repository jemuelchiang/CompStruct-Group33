module test_values (
    input index[5],
    output a[32],
    output b[32], 
    output s[32],
    output alufn[6],
    output z,
    output v,
    output n
) {
    const TEST_VALUES = $reverse(
        {
            c{32d0,          32d0,          6h00, c{32d0,          1b1,1b0,1b0}}, // 00 ADD 0+0
            c{32h7FFFFFFF,   32d1,          6h00, c{32h80000000,   1b0,1b1,1b1}}, // 01 ADD pos overflow
            
            c{32d7,          32d5,          6h01, c{32d2,          1b0,1b0,1b0}}, // 02 SUB 7-5
            c{32h80000000,   32d1,          6h01, c{32h7FFFFFFF,   1b0,1b1,1b0}}, // 03 SUB neg overflow
            
            c{32d3,          32d4,          6h02, c{32d12,         1b0,1b0,1b0}}, // 04 MUL 3*4
            c{32h80000000,   32d2,          6h02, c{32d0,          1b0,1b0,1b1}}, // 05 MUL 80000000*2
            
            c{32hF0F0F0F0,   32h0F0F0F0F,   6h18, c{32h00000000,   1b0,1b0,1b1}}, // 06 AND mask clears to zero
            c{32hF0F0F0F0,   32h0F0F0F0F,   6h1E, c{32hFFFFFFFF,   1b0,1b0,1b1}}, // 07 OR fills all bits
            c{32hAAAA5555,   32hFFFF0000,   6h16, c{32h55555555,   1b0,1b0,1b1}}, // 08 XOR pattern
            
            c{32d5,          32d7,          6h1A, c{32d5,          1b0,1b0,1b0}}, // 09 PASSA 5,7
            
            c{32d1,          32d3,          6h20, c{32d8,          1b0,1b0,1b0}}, // 10 SHL 1<<3
            c{32d16,         32d1,          6h21, c{32d8,          1b0,1b0,1b0}}, // 11 SHR 16>>1
            c{32h80000000,   32d1,          6h23, c{32hC0000000,   1b0,1b1,1b0}}, // 12 SRA 80000000>>1
            
            c{32d5,          32d5,          6h33, c{32d1,          1b1,1b0,1b0}}, // 13 CMPEQ 5==5
            c{32d3,          32d7,          6h35, c{32d1,          1b0,1b0,1b1}}, // 14 CMPLT 3<7 true
            c{32d5,          32d5,          6h37, c{32d1,          1b1,1b0,1b0}},  // 15 CMPLE 5<=5
            
            c{32hFFFFFFFF,   32d1,          6h00, c{32d0,          1b1,1b0,1b0}}, // 16 ADD -1 + 1 = 0
            c{32h80000000,   32hFFFFFFFF,   6h00, c{32h7FFFFFFF,   1b0,1b1,1b0}}, // 17 ADD neg overflow

            c{32h12345678,   32h12345678,   6h01, c{32d0,          1b1,1b0,1b0}}, // 18 SUB equal values
            c{32d0,          32d1,          6h01, c{32hFFFFFFFF,   1b0,1b0,1b1}}, // 19 SUB 0 - 1

            c{32h12345678,   32d0,          6h02, c{32d0,          1b0,1b0,1b0}}, // 20 MUL by zero
            c{32h00010000,   32h00010000,   6h02, c{32d0,          1b0,1b0,1b0}}, // 21 MUL low 32 bits truncate to 0

            c{32h12345678,   32h00FF00FF,   6h18, c{32h00340078,   1b0,1b0,1b0}}, // 22 AND partial mask
            c{32h12340000,   32h00005678,   6h1E, c{32h12345678,   1b0,1b0,1b0}}, // 23 OR combine halves
            c{32hDEADBEEF,   32hDEADBEEF,   6h16, c{32d0,          1b0,1b0,1b1}}, // 24 XOR self = 0

            c{32h80000001,   32h12345678,   6h1A, c{32h80000001,   1b0,1b0,1b1}}, // 25 PASSA negative value

            c{32h40000000,   32d1,          6h20, c{32h80000000,   1b0,1b0,1b0}}, // 26 SHL into sign bit
            c{32d17,         32d1,          6h21, c{32d8,          1b0,1b0,1b0}}, // 27 SHR 17 >> 1
            c{32hFFFFFFFF,   32d4,          6h23, c{32hFFFFFFFF,   1b0,1b0,1b1}}, // 28 SRA keeps sign

            c{32d5,          32d7,          6h33, c{32d0,          1b0,1b0,1b1}}, // 29 CMPEQ false
            c{32d7,          32d3,          6h35, c{32d0,          1b0,1b0,1b0}}, // 30 CMPLT false
            c{32d9,          32d4,          6h37, c{32d0,          1b0,1b0,1b0}} // 31 CMPLE false
        }
    )
    
    always {
        a = TEST_VALUES[index][104:73]
        b = TEST_VALUES[index][72:41]
        alufn = TEST_VALUES[index][40:35]
        s = TEST_VALUES[index][34:3]
        z = TEST_VALUES[index][2]
        v = TEST_VALUES[index][1]
        n = TEST_VALUES[index][0]
    }
}
