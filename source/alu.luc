module alu (
    input a[32],
    input b[32],
    input alufn[6],
    output out[32],
    output z,
    output v,
    output n
) {

    adder adder(#SIZE(32))
    multiplier multiplier
    boolean boolean
    shifter shifter
    compare compare
    
    always {
        // adder
        adder.a = a
        adder.b = b
        adder.alufn = alufn
        
        z = adder.z
        v = adder.v
        n = adder.n

        // multiplier
        multiplier.a = a
        multiplier.b = b

        //boolean
        boolean.a = a
        boolean.b = b
        boolean.alufn = alufn

        //shifter
        shifter.a = a
        shifter.b = b
        shifter.alufn = alufn

        //compare
        compare.z = adder.z
        compare.v = adder.v
        compare.n = adder.n
        compare.alufn = alufn
        
        case(alufn){
            b000000: out = adder.s
            b000001: out = adder.s

            b000010: out = multiplier.mul

            b011000: out = boolean.bool
            b011110: out = boolean.bool
            b010110: out = boolean.bool
            b011010: out = boolean.bool

            b100000: out = shifter.shift
            b100001: out = shifter.shift
            b100011: out = shifter.shift

            b110011: out = compare.cmp
            b110101: out = compare.cmp
            b110111: out = compare.cmp
                
            default: out = 0
        }
        
        
    }
}
